{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "es2019",
    "module": "es2020",
    "lib": ["dom", "ES2021"],
    "moduleResolution": "bundler",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["**/*.ts"]
}